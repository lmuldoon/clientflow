{
  "extends": [
    "plugin:@wordpress/eslint-plugin/recommended",
    "plugin:@wordpress/eslint-plugin/jsx-a11y"
  ],
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "no-console": "warn",
    "prefer-const": "error",
    "no-unused-vars": "error",
    "@wordpress/no-unsafe-wp-apis": "warn",
    "import/no-extraneous-dependencies": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    "build/",
    "vendor/",
    "*.min.js"
  ]
}
